# Server
PORT=3001
NODE_ENV=development

# AI
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional fallback when Gemini's free tier hits a 429/503 — get a free key at
# https://openrouter.ai/keys. Leave blank to disable (Gemini errors will just fail the job).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Database
MONGO_URI=
MONGO_DB_NAME=job_application_agent

# Gmail (for cold emails + notifications)
GMAIL_USER=riteshkr0759@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_REFERRAL_USER=ritesh7882@gmail.com
GMAIL_REFERRAL_APP_PASSWORD=

# Scraping
# Comma-separate multiple keyword sets — scrapeAll() uses this as one combined search.
# Cover your target roles: frontend, backend, full stack, IT support, tech support, entry level.
SCRAPE_KEYWORDS=frontend developer OR backend developer OR full stack developer OR software engineer OR IT support entry level
SCRAPE_LOCATION=India
SCRAPE_LIMIT=20
MIN_ELIGIBILITY_SCORE=60

# Queue
REDIS_URL=redis://localhost:6379

# Auto-apply safety
INTERNSHALA_DRY_RUN=true
AUTO_APPLY_DRY_RUN=true
INDEED_DRY_RUN=true
NAUKRI_DRY_RUN=true
NOTIFICATION_EMAIL=riteshkr0759@gmail.com
DASHBOARD_URL=http://localhost:5173

# Credential vault — encrypts stored Indeed/Naukri passwords at rest when set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left blank, credentials are stored in plain text instead (file is still gitignored).
CREDENTIAL_VAULT_KEY=

# Never log in to the same platform more than once per this many hours, even on a
# failed attempt or expired session — anti-bot-detection hygiene.
MIN_HOURS_BETWEEN_LOGINS=6

# LinkedIn referral networking (applicators/linkedinNetworking.js)
# Use a SECONDARY test account first — automated actions risk your primary account.
# See the "NOTES FOR REAL ACCOUNT" block in linkedinNetworking.js before switching.
LINKEDIN_NETWORKING_ENABLED=false          # must explicitly set true to activate
LINKEDIN_NETWORKING_EMAIL=                 # LinkedIn login email for networking account
LINKEDIN_NETWORKING_PASSWORD=              # LinkedIn login password
LINKEDIN_DRY_RUN=true                      # true = finds profiles but never clicks Send
LINKEDIN_MAX_REQUESTS_PER_DAY=3            # hard daily cap (default 3, max safe ~5)
LINKEDIN_MAX_PER_COMPANY=3                 # max profiles to contact per job/company

# HR email finder
# Hunter.io — free tier: 25 domain searches/month. Get key at https://hunter.io/api-keys
# Cache prevents burning credits on same domain twice in one pipeline run.
API_HUNTER_API_KEY=
# Apollo.io — future addition when Hunter credits run out
# APOLLO_API_KEY=

# LaTeX
LATEX_COMPILER=auto
